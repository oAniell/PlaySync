# Variáveis de ambiente do frontend
# Copie este arquivo para .env e configure os valores

# URL da API do backend
# Para desenvolvimento local: http://localhost:8080
# Para produção (VM Oracle): http://<IP-DA-VM>:8080
VITE_API_URL=http://localhost:8080

# Configurações de ambiente
VITE_APP_NAME=PlaySync
VITE_APP_VERSION=1.0.0

# Configurações de API externas (opcional)
# VITE_CHEAPSHARK_API_URL=https://www.cheapshark.com/api
# VITE_RAWG_API_URL=https://api.rawg.io/api
